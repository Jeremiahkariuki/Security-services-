<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_guard" model="ir.actions.report">
        <field name="name">Guard Profile</field>
        <field name="model">security.guard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">security_services.report_guard_template</field>
        <field name="report_file">security_services.report_guard_template</field>
        <field name="binding_model_id" ref="model_security_guard"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_guard_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">GUARD PROFILE</h2>
                        <hr/>
                        <div class="row">
                            <div class="col-8">
                                <h3><t t-esc="doc.name"/></h3>
                                <table class="table table-bordered">
                                    <tr>
                                        <th>ID Number</th>
                                        <td><t t-esc="doc.id_number"/></td>
                                        <th>Status</th>
                                        <td><t t-esc="doc.status"/></td>
                                    </tr>
                                    <tr>
                                        <th>Phone</th>
                                        <td><t t-esc="doc.phone or '-'"/></td>
                                        <th>Email</th>
                                        <td><t t-esc="doc.email or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <th>Assigned Site</th>
                                        <td><t t-esc="doc.site_id.name or '-'"/></td>
                                        <th>Supervisor</th>
                                        <td><t t-esc="doc.supervisor_id.name or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <th>Contract Start</th>
                                        <td><t t-esc="doc.contract_start"/></td>
                                        <th>Contract End</th>
                                        <td><t t-esc="doc.contract_end"/></td>
                                    </tr>
                                    <tr>
                                        <th>Basic Salary</th>
                                        <td>KES <t t-esc="'{:,.2f}'.format(doc.basic_salary)"/></td>
                                        <th>House Allowance</th>
                                        <td>KES <t t-esc="'{:,.2f}'.format(doc.house_allowance)"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
