<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Security Groups -->
        <record id="group_security_guard" model="res.groups">
            <field name="name">Guard</field>
            <field name="category_id"
                   ref="base.module_category_human_resources"/>
        </record>

        <record id="group_security_supervisor" model="res.groups">
            <field name="name">Supervisor</field>
            <field name="category_id"
                   ref="base.module_category_human_resources"/>
            <field name="implied_ids"
                   eval="[(4, ref('group_security_guard'))]"/>
        </record>

        <record id="group_security_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id"
                   ref="base.module_category_human_resources"/>
            <field name="implied_ids"
                   eval="[(4, ref('group_security_supervisor'))]"/>
        </record>

        <record id="group_security_hr" model="res.groups">
            <field name="name">HR Manager</field>
            <field name="category_id"
                   ref="base.module_category_human_resources"/>
            <field name="implied_ids"
                   eval="[(4, ref('group_security_manager'))]"/>
        </record>

        <record id="group_security_accounts" model="res.groups">
            <field name="name">Accounts Officer</field>
            <field name="category_id"
                   ref="base.module_category_human_resources"/>
            <field name="implied_ids"
                   eval="[(4, ref('group_security_manager'))]"/>
        </record>

        <record id="group_security_ceo" model="res.groups">
            <field name="name">CEO</field>
            <field name="category_id"
                   ref="base.module_category_human_resources"/>
            <field name="implied_ids"
                   eval="[(4, ref('group_security_hr'))]"/>
        </record>

        <!-- Record Rules -->

        <!-- Guards can only see their own records -->
        <record id="rule_guard_own_record" model="ir.rule">
            <field name="name">Guard: Own Record Only</field>
            <field name="model_id" ref="model_security_guard"/>
            <field name="domain_force">
                ['|',
                 ('id', 'in', []),
                 (1, '=', 1)]
            </field>
            <field name="groups"
                   eval="[(4, ref('group_security_ceo'))]"/>
        </record>

        <!-- Guards see only their own shifts -->
        <record id="rule_shift_guard" model="ir.rule">
            <field name="name">Guard: Own Shifts Only</field>
            <field name="model_id" ref="model_security_shift"/>
            <field name="domain_force">
                [('guard_id.email', '=', user.email)]
            </field>
            <field name="groups"
                   eval="[(4, ref('group_security_guard'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Guards see only their own attendance -->
        <record id="rule_attendance_guard" model="ir.rule">
            <field name="name">Guard: Own Attendance Only</field>
            <field name="model_id" ref="model_security_attendance"/>
            <field name="domain_force">
                [('guard_id.email', '=', user.email)]
            </field>
            <field name="groups"
                   eval="[(4, ref('group_security_guard'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Guards see only their own payslips -->
        <record id="rule_payslip_guard" model="ir.rule">
            <field name="name">Guard: Own Payslips Only</field>
            <field name="model_id" ref="model_security_payslip"/>
            <field name="domain_force">
                [('guard_id.email', '=', user.email)]
            </field>
            <field name="groups"
                   eval="[(4, ref('group_security_guard'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Guards see only their own complaints -->
        <record id="rule_complaint_guard" model="ir.rule">
            <field name="name">Guard: Own Complaints Only</field>
            <field name="model_id" ref="model_security_complaint"/>
            <field name="domain_force">
                [('guard_id.email', '=', user.email)]
            </field>
            <field name="groups"
                   eval="[(4, ref('group_security_guard'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Accounts Officer sees Finance only -->
        <record id="rule_payslip_accounts" model="ir.rule">
            <field name="name">Accounts: All Payslips</field>
            <field name="model_id" ref="model_security_payslip"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('group_security_accounts'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
