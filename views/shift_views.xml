<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Shift List View -->
    <record id="view_security_shift_list" model="ir.ui.view">
        <field name="name">security.shift.list</field>
        <field name="model">security.shift</field>
        <field name="arch" type="xml">
            <tree string="Shifts"
                  decoration-success="state == 'done'"
                  decoration-info="state == 'ongoing'"
                  decoration-warning="state == 'draft'"
                  decoration-danger="state == 'cancelled'">
                <field name="date"/>
                <field name="guard_id"/>
                <field name="site_id"/>
                <field name="shift_type" widget="badge"
                       decoration-info="shift_type == 'day'"
                       decoration-warning="shift_type == 'night'"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
                <field name="hours_worked"/>
                <field name="supervisor_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'ongoing'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- Shift Form View -->
    <record id="view_security_shift_form" model="ir.ui.view">
        <field name="name">security.shift.form</field>
        <field name="model">security.shift</field>
        <field name="arch" type="xml">
            <form string="Shift">
                <header>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_start"
                            string="Start Shift"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_done"
                            string="End Shift"
                            type="object"
                            class="btn-success"
                            invisible="state != 'ongoing'"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state in ['done','cancelled']"/>
                    <button name="action_reset"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,ongoing,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Assignment">
                            <field name="guard_id"/>
                            <field name="site_id"/>
                            <field name="supervisor_id"/>
                            <field name="replacement_id"/>
                        </group>
                        <group string="Schedule">
                            <field name="date"/>
                            <field name="shift_type"/>
                            <field name="start_time" widget="float_time"/>
                            <field name="end_time" widget="float_time"/>
                            <field name="hours_worked" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Attendance">
                            <field name="checked_in"/>
                            <field name="checked_out"/>
                        </group>
                        <group string="Roster">
                            <field name="roster_id"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Shift Calendar View -->
    <record id="view_security_shift_calendar" model="ir.ui.view">
        <field name="name">security.shift.calendar</field>
        <field name="model">security.shift</field>
        <field name="arch" type="xml">
            <calendar string="Shift Schedule"
                      date_start="date"
                      color="site_id"
                      mode="month">
                <field name="guard_id"/>
                <field name="site_id"/>
                <field name="shift_type"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- Shift Search View -->
    <record id="view_security_shift_search" model="ir.ui.view">
        <field name="name">security.shift.search</field>
        <field name="model">security.shift</field>
        <field name="arch" type="xml">
            <search>
                <field name="guard_id"/>
                <field name="site_id"/>
                <field name="date"/>
                <filter name="today" string="Today"
                        domain="[('date','=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_week" string="This Week"
                        domain="[('date','&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter name="draft" string="Draft"
                        domain="[('state','=','draft')]"/>
                <filter name="confirmed" string="Confirmed"
                        domain="[('state','=','confirmed')]"/>
                <filter name="ongoing" string="Ongoing"
                        domain="[('state','=','ongoing')]"/>
                <filter name="done" string="Done"
                        domain="[('state','=','done')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_guard" string="Guard"
                            context="{'group_by':'guard_id'}"/>
                    <filter name="group_site" string="Site"
                            context="{'group_by':'site_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by':'date'}"/>
                    <filter name="group_type" string="Shift Type"
                            context="{'group_by':'shift_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Roster List View -->
    <record id="view_security_roster_list" model="ir.ui.view">
        <field name="name">security.roster.list</field>
        <field name="model">security.roster</field>
        <field name="arch" type="xml">
            <tree string="Rosters">
                <field name="name"/>
                <field name="site_id"/>
                <field name="week_start"/>
                <field name="week_end"/>
                <field name="shift_count"/>
                <field name="manager_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'published'"
                       decoration-warning="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <!-- Roster Form View -->
    <record id="view_security_roster_form" model="ir.ui.view">
        <field name="name">security.roster.form</field>
        <field name="model">security.roster</field>
        <field name="arch" type="xml">
            <form string="Roster">
                <header>
                    <button name="action_publish"
                            string="Publish Roster"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,published"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="site_id"/>
                            <field name="week_start"/>
                            <field name="week_end" readonly="1"/>
                            <field name="manager_id"/>
                        </group>
                        <group string="Summary">
                            <field name="shift_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Shifts">
                            <field name="shift_ids">
                                <tree editable="bottom">
                                    <field name="date"/>
                                    <field name="guard_id"/>
                                    <field name="shift_type"/>
                                    <field name="start_time"
                                           widget="float_time"/>
                                    <field name="end_time"
                                           widget="float_time"/>
                                    <field name="supervisor_id"/>
                                    <field name="state" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_security_shift" model="ir.actions.act_window">
        <field name="name">Shifts</field>
        <field name="res_model">security.shift</field>
        <field name="view_mode">tree,form,calendar</field>
        <field name="search_view_id" ref="view_security_shift_search"/>
    </record>

    <record id="action_security_roster" model="ir.actions.act_window">
        <field name="name">Rosters</field>
        <field name="res_model">security.roster</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
