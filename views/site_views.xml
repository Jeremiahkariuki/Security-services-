<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_security_site_list" model="ir.ui.view">
        <field name="name">security.site.list</field>
        <field name="model">security.site</field>
        <field name="arch" type="xml">
            <tree string="Sites">
                <field name="name"/>
                <field name="client_id"/>
                <field name="location"/>
                <field name="risk_level" widget="badge"
                       decoration-danger="risk_level == 'critical'"
                       decoration-warning="risk_level == 'high'"/>
                <field name="required_guards"/>
                <field name="guard_count"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"/>
            </tree>
        </field>
    </record>

    <record id="view_security_site_form" model="ir.ui.view">
        <field name="name">security.site.form</field>
        <field name="model">security.site</field>
        <field name="arch" type="xml">
            <form string="Site">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Site Details">
                            <field name="client_id"/>
                            <field name="location"/>
                            <field name="risk_level"/>
                            <field name="required_guards"/>
                            <field name="status"/>
                        </group>
                        <group string="Contract">
                            <field name="contract_start"/>
                            <field name="contract_end"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Assigned Guards">
                            <field name="guard_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="id_number"/>
                                    <field name="phone"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_security_site" model="ir.actions.act_window">
        <field name="name">Sites</field>
        <field name="res_model">security.site</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
