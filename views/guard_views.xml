<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_security_guard_list" model="ir.ui.view">
        <field name="name">security.guard.list</field>
        <field name="model">security.guard</field>
        <field name="arch" type="xml">
            <tree string="Guards"
                  decoration-danger="status == 'terminated'"
                  decoration-warning="status == 'suspended'">
                <field name="name"/>
                <field name="id_number"/>
                <field name="phone"/>
                <field name="site_id"/>
                <field name="contract_end"/>
                <field name="basic_salary"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-danger="status == 'terminated'"
                       decoration-warning="status == 'suspended'"/>
            </tree>
        </field>
    </record>

    <record id="view_security_guard_form" model="ir.ui.view">
        <field name="name">security.guard.form</field>
        <field name="model">security.guard</field>
        <field name="arch" type="xml">
            <form string="Security Guard">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="active,suspended,terminated"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Full Name"/></h1>
                    </div>
                    <group>
                        <group string="Personal Information">
                            <field name="id_number"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                        </group>
                        <group string="Employment">
                            <field name="site_id"/>
                            <field name="supervisor_id"/>
                            <field name="contract_start"/>
                            <field name="contract_end"/>
                            <field name="contract_duration" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Salary">
                            <field name="basic_salary"/>
                            <field name="house_allowance"/>
                            <field name="transport_allowance"/>
                        </group>
                        <group string="Photo">
                            <field name="photo" widget="image"
                                   class="oe_avatar"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_security_guard_search" model="ir.ui.view">
        <field name="name">security.guard.search</field>
        <field name="model">security.guard</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="id_number"/>
                <field name="site_id"/>
                <filter name="active" string="Active"
                        domain="[('status','=','active')]"/>
                <filter name="suspended" string="Suspended"
                        domain="[('status','=','suspended')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_site" string="Site"
                            context="{'group_by':'site_id'}"/>
                    <filter name="group_status" string="Status"
                            context="{'group_by':'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_security_guard" model="ir.actions.act_window">
        <field name="name">Guards</field>
        <field name="res_model">security.guard</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_security_guard_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
